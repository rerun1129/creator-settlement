@host = http://localhost:9090

# ============================================================
# 매출 조회 시나리오 (GET /api/sales)
#
# 검증 대상:
#   - 정상 조회 (정상 범위, creatorId 필터 유무)
#   - 시간 경계 (from 포함, toExclusive 배타)
#   - from > toExclusive → 400 LIST_SALES_PERIOD_INVALID
#   - from == toExclusive → 200 [] (도메인 통과, 빈 결과)
#   - 빈 결과
#   - 부분 환불 반영
#   - 동일 시각 다건
#
# 사용법:
#   - 일부 시나리오는 사전 등록 필요 (단계별 절차 코멘트 참고)
#   - salesRecordId가 0으로 박힌 자리는 SQL 결과로 교체
#   - 시나리오 간 격리: studentId 9301~9399 범위 권장
#
# 전제:
#   - 서버 9090 부팅 상태
#   - courseId 1이 DB에 존재
#   - 시나리오 5는 courseId 1의 creatorId가 1이라고 가정 (시드 따라 조정)
#
# DB cleanup:
#   DELETE FROM cancellation_record WHERE sales_record_id IN (
#       SELECT sales_record_id FROM sales_record
#       WHERE student_id BETWEEN 9300 AND 9399);
#   DELETE FROM sales_record WHERE student_id BETWEEN 9300 AND 9399;
# ============================================================


# ============================================================
# [Q01] 빈 범위 조회 → 200 []
# ============================================================

### Q01 매출 없는 먼 과거 범위 (기대: 200, [])
GET {{host}}/api/sales?from=1990-01-01T00:00:00&toExclusive=1990-02-01T00:00:00


# ============================================================
# [Q02] 등록 후 같은 범위 조회 → 200, 해당 매출 포함
# ============================================================

### Q02-A 등록 (사전 조건, 기대: 201)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9301, "paymentAmount": 49000, "paidAt": "2026-08-15T10:00:00" }

### Q02-B 같은 시각 포함 범위 조회 (기대: 200, 위 매출 포함)
GET {{host}}/api/sales?from=2026-08-01T00:00:00&toExclusive=2026-09-01T00:00:00


# ============================================================
# [Q03] toExclusive 경계 — paidAt == toExclusive면 미포함 (배타적 끝)
# ============================================================

### Q03-A 등록 paidAt 정확히 2026-09-01T00:00:00 (사전 조건)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9302, "paymentAmount": 49000, "paidAt": "2026-09-01T00:00:00" }

### Q03-B 8월 범위로 조회 (toExclusive == paidAt → 미포함, 기대: 200, Q03-A 매출 없음)
GET {{host}}/api/sales?from=2026-08-01T00:00:00&toExclusive=2026-09-01T00:00:00


# ============================================================
# [Q04] from 경계 — paidAt == from이면 포함 (포함적 시작)
#   ※ Q03-A를 먼저 실행해야 의미 있음
# ============================================================

### Q04 9월 범위로 조회 (from == paidAt → 포함, 기대: 200, Q03-A 매출 포함)
GET {{host}}/api/sales?from=2026-09-01T00:00:00&toExclusive=2026-10-01T00:00:00


# ============================================================
# [Q05] creatorId 필터 일치 → 200, 해당 creator 매출만
#   ※ courseId=1의 creatorId가 1이라고 가정 (시드에 따라 조정)
# ============================================================

### Q05 creatorId=1, 2026-08 ~ 10 범위 (기대: 200, Q02·Q03 매출 포함)
GET {{host}}/api/sales?creatorId=1&from=2026-08-01T00:00:00&toExclusive=2026-10-01T00:00:00


# ============================================================
# [Q06] creatorId 필터 불일치 → 200, []
# ============================================================

### Q06 존재하지 않는 creatorId (기대: 200, [])
GET {{host}}/api/sales?creatorId=999999&from=2026-08-01T00:00:00&toExclusive=2026-10-01T00:00:00


# ============================================================
# [Q07] from > toExclusive → 400 LIST_SALES_PERIOD_INVALID
#   ListSalesQuery compact constructor에서 던짐
# ============================================================

### Q07 from > toExclusive (기대: 400 LIST_SALES_PERIOD_INVALID)
GET {{host}}/api/sales?from=2026-12-31T23:59:59&toExclusive=2026-01-01T00:00:00


# ============================================================
# [Q08] from == toExclusive → 200 [] (validation 통과, 도메인 빈 결과)
#   ListSalesQuery는 isAfter만 체크, equal은 통과
# ============================================================

### Q08 from == toExclusive (기대: 200, [])
GET {{host}}/api/sales?from=2026-05-23T10:00:00&toExclusive=2026-05-23T10:00:00


# ============================================================
# [Q09] 매출 + 부분 환불 후 조회 → 응답에 환불 반영 확인 (응답 구조 점검)
# ============================================================

### Q09-A 등록 100,000 (사전 조건, 기대: 201)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9303, "paymentAmount": 100000, "paidAt": "2026-10-15T10:00:00" }

### [SQL] SELECT sales_record_id FROM sales_record WHERE student_id = 9303 ORDER BY sales_record_id DESC LIMIT 1;

### Q09-C 부분 환불 30,000 (사전 조건)
POST {{host}}/api/sales/cancellations
Content-Type: application/json

{ "salesRecordId": 0, "refundAmount": 30000, "cancelledAt": "2026-10-16T10:00:00" }

### Q09-D 조회 (기대: 200, 응답에 환불·잔여 정보 반영 — 응답 구조 직접 확인)
GET {{host}}/api/sales?from=2026-10-01T00:00:00&toExclusive=2026-11-01T00:00:00


# ============================================================
# [Q10] 동일 시각 다건 → 200, 다건 응답
# ============================================================

### Q10-A 동일 시각 등록 1 (사전 조건)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9304, "paymentAmount": 49000, "paidAt": "2026-11-01T12:00:00" }

### Q10-B 동일 시각 등록 2 (사전 조건)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9305, "paymentAmount": 49000, "paidAt": "2026-11-01T12:00:00" }

### Q10-C 동일 시각 등록 3 (사전 조건)
POST {{host}}/api/sales
Content-Type: application/json

{ "courseId": 1, "studentId": 9306, "paymentAmount": 49000, "paidAt": "2026-11-01T12:00:00" }

### Q10-D 해당 시각 포함 1분 범위 조회 (기대: 200, 3건)
GET {{host}}/api/sales?from=2026-11-01T12:00:00&toExclusive=2026-11-01T12:01:00
